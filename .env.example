# ------------------------------------------------------------------
# Valor Futuro · Variáveis de ambiente
# Copia este ficheiro para `.env` para desenvolvimento local.
# Em produção (Render), define-as no painel ou via render.yaml.
# ------------------------------------------------------------------

# Modo: 'development' (debug, hot reload) ou 'production'
FLASK_ENV=development

# Chave secreta para sessões/cookies. Em produção, gera uma forte:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# No Render, deixa o `render.yaml` gerar (generateValue: true).
SECRET_KEY=change-me-in-production

# Base de dados — PostgreSQL (recomendado, dev e produção)
# Obtém uma URL grátis em:
#   • https://neon.tech       (Cloud, 0.5 GB grátis)
#   • https://supabase.com    (Cloud, 500 MB grátis)
#   • Render Postgres         (External Database URL do teu projecto)
#   • Local: postgresql://postgres:senha@localhost:5432/valor_futuro
DATABASE_URL=postgresql://user:pass@host:5432/valor_futuro

# Fallback temporário em SQLite (não recomendado em produção):
# DATABASE_URL=sqlite:///valor_futuro.db

# Cookies só por HTTPS (1 em produção, 0 em dev local)
SESSION_COOKIE_SECURE=0

# Pasta de uploads. Em Render com disco persistente, aponta para o mount path.
# UPLOAD_FOLDER=/var/data/uploads

# Porta. Localmente 5000; no Render é injectada automaticamente.
PORT=5000

# Opcional — Google Maps (não usado no embed simples actual).
# GOOGLE_MAPS_API_KEY=
